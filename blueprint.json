{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Wikipedia Fact-Check 1.0.6",
		"author": "Ross Mulcahy"
	},
	"landingPage": "/wp-admin/post-new.php",
	"preferredVersions": {
		"php": "8.2",
		"wp": "6.7"
	},
	"steps": [
		{
			"step": "login",
			"username": "admin",
			"password": "password"
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/ross-mulcahy/wp-wikipedia-factcheck",
				"ref": "codex-fix-wikipedia-lookup",
				"refType": "branch",
				"path": "/"
			},
			"options": {
				"activate": true,
				"targetFolderName": "wp-wikipedia-factcheck"
			}
		}
	]
}
