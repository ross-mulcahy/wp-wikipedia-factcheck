{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-wikipedia-factcheck/fact-box",
	"title": "Wikipedia Fact Box",
	"category": "widgets",
	"icon": "excerpt-view",
	"description": "Create a compact fact box from Wikipedia and AI-selected fact candidates.",
	"textdomain": "wp-wikipedia-factcheck",
	"editorScript": "wp-wikipedia-factcheck-editor",
	"style": "wp-wikipedia-factcheck-style",
	"editorStyle": "wp-wikipedia-factcheck-style",
	"attributes": {
		"term": {
			"type": "string",
			"default": ""
		},
		"headline": {
			"type": "string",
			"default": ""
		},
		"fact": {
			"type": "string",
			"default": ""
		},
		"articleUrl": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false
	}
}
